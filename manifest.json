{
  "manifest_version": 3,
  "name": "tataycs notches",
  "description": "A feature-rich browser notepad with tabs, templates, auto-save, dark mode, and more.",
  "version": "4.0.0",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
